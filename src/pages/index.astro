---
import Layout from "../layouts/Layout.astro";
---

<Layout title="TimeLog">
  <div class="app-shell">
    <header class="topbar">
      <div>
        <p class="eyebrow">Registro local y offline</p>
        <h1 class="brand">Time<span>Log</span></h1>
      </div>
      <div class="topbar-meta">
        <span id="current-date" class="date-chip"></span>
        <button id="settings-btn" class="ghost-btn compact-btn" type="button" aria-expanded="false" aria-controls="settings-panel">
          Ajustes
        </button>
      </div>
    </header>

    <section id="settings-panel" class="panel hidden" aria-label="Ajustes de la app">
      <div class="settings-inner stack-lg">
        <div class="section-head">
          <div>
            <p class="eyebrow">Preferencias</p>
            <h2 class="section-title">Metas, avisos y respaldo</h2>
          </div>
          <span id="storage-status" class="status-badge">Guardado local automatico</span>
        </div>

        <div class="settings-grid">
          <div class="stack-md">
            <label class="field-label" for="daily-goal-input">Meta diaria (horas)</label>
            <input id="daily-goal-input" class="field-input" type="number" min="1" max="24" step="0.5" />
          </div>
          <div class="stack-md">
            <label class="field-label" for="weekly-goal-input">Meta semanal (horas)</label>
            <input id="weekly-goal-input" class="field-input" type="number" min="1" max="80" step="1" />
          </div>
          <div class="stack-md settings-actions">
            <button id="save-goals-btn" class="primary-btn" type="button">Guardar metas</button>
            <p id="last-export-status" class="tiny-copy"></p>
            <p id="backup-nudge" class="tiny-copy warning-copy hidden"></p>
          </div>
        </div>

        <div class="stack-md">
          <span class="field-label">Aviso al acumular hoy</span>
          <div class="chip-row">
            <button class="notif-opt chip-btn" data-hours="" type="button">Off</button>
            <button class="notif-opt chip-btn" data-hours="2" type="button">2h</button>
            <button class="notif-opt chip-btn" data-hours="4" type="button">4h</button>
            <button class="notif-opt chip-btn" data-hours="6" type="button">6h</button>
            <button class="notif-opt chip-btn" data-hours="8" type="button">8h</button>
          </div>
          <p id="notif-status" class="tiny-copy"></p>
        </div>
      </div>
    </section>

    <main class="stack-xl">
      <section class="hero-grid">
        <section class="panel timer-panel">
          <div class="section-head">
            <div>
              <p class="eyebrow">Sesion activa</p>
              <h2 class="section-title">Control rapido</h2>
            </div>
            <div class="timer-status">
              <span id="status-dot" class="status-dot" aria-hidden="true"></span>
              <span id="timer-state-label" class="tiny-copy">Listo para empezar</span>
            </div>
          </div>

          <div class="timer-stack">
            <p id="timer" class="timer-display">00:00:00</p>

            <div class="stack-md">
              <label class="field-label" for="project-input">Proyecto</label>
              <input
                id="project-input"
                type="text"
                list="projects-datalist"
                placeholder="Cliente, sprint o area"
                maxlength="50"
                autocomplete="off"
                class="field-input"
              />
              <datalist id="projects-datalist"></datalist>
            </div>

            <div class="stack-md">
              <label class="field-label" for="note-input">Nota de trabajo</label>
              <input
                id="note-input"
                type="text"
                placeholder="Que estas haciendo ahora"
                maxlength="200"
                autocomplete="off"
                class="field-input"
              />
            </div>

            <div id="btn-area" class="button-grid">
              <button id="start-btn" class="primary-btn big-btn" type="button">Iniciar</button>
              <button id="pause-btn" class="ghost-btn big-btn hidden" type="button">Pausar</button>
              <button id="resume-btn" class="primary-btn big-btn hidden" type="button">Reanudar</button>
              <button id="stop-btn" class="ghost-btn big-btn danger-btn hidden" type="button">Detener</button>
            </div>

            <p class="tiny-copy">Atajo: <kbd>Espacio</kbd> para iniciar, pausar o reanudar.</p>
          </div>
        </section>

        <section class="panel cadence-panel">
          <div class="section-head">
            <div>
              <p class="eyebrow">Cadencia</p>
              <h2 class="section-title">Objetivos y respaldo</h2>
            </div>
            <span class="panel-accent">Local first</span>
          </div>

          <div class="stack-lg">
            <div class="goal-card">
              <div class="goal-copy">
                <span class="field-label">Meta diaria</span>
                <span id="daily-goal-label" class="goal-value">0h / 0h</span>
              </div>
              <div class="progress-track"><div id="daily-goal-bar" class="progress-fill"></div></div>
            </div>

            <div class="goal-card">
              <div class="goal-copy">
                <span class="field-label">Meta semanal</span>
                <span id="weekly-goal-label" class="goal-value">0h / 0h</span>
              </div>
              <div class="progress-track"><div id="weekly-goal-bar" class="progress-fill warm"></div></div>
            </div>

            <div class="trust-card">
              <p class="field-label">Salud del historial</p>
              <p id="trust-copy" class="trust-copy"></p>
              <p id="trust-extra" class="tiny-copy"></p>
            </div>
          </div>
        </section>
      </section>

      <section class="stats-grid">
        <article class="stat-card">
          <span class="eyebrow">Hoy</span>
          <strong id="stat-today" class="stat-value">0h 0m</strong>
        </article>
        <article class="stat-card">
          <span class="eyebrow">Semana</span>
          <strong id="stat-week" class="stat-value">0h 0m</strong>
        </article>
        <article class="stat-card">
          <span class="eyebrow">Sesiones</span>
          <strong id="stat-sessions" class="stat-value">0</strong>
        </article>
        <article class="stat-card">
          <span class="eyebrow">Proyectos activos</span>
          <strong id="stat-projects" class="stat-value">0</strong>
        </article>
      </section>

      <section class="insight-grid">
        <section class="panel stack-lg">
          <div class="section-head">
            <div>
              <p class="eyebrow">Distribucion</p>
              <h2 class="section-title">Horas por proyecto</h2>
            </div>
            <div class="chip-row">
              <button id="insight-week-btn" class="chip-btn active" type="button">Semana</button>
              <button id="insight-month-btn" class="chip-btn" type="button">Mes</button>
            </div>
          </div>

          <div id="project-insights-list" class="stack-sm"></div>
          <p id="project-insights-empty" class="tiny-copy hidden">Todavia no hay horas con proyecto para este periodo.</p>
        </section>

        <section class="panel stack-lg">
          <div class="section-head">
            <div>
              <p class="eyebrow">Reporte</p>
              <h2 class="section-title">Resumen exportable</h2>
            </div>
            <span id="report-range" class="status-badge">Todo el historial</span>
          </div>

          <div class="report-grid">
            <article class="report-metric">
              <span class="field-label">Horas</span>
              <strong id="report-hours" class="report-value">0.0h</strong>
            </article>
            <article class="report-metric">
              <span class="field-label">Sesiones</span>
              <strong id="report-sessions" class="report-value">0</strong>
            </article>
            <article class="report-metric">
              <span class="field-label">Proyectos</span>
              <strong id="report-projects" class="report-value">0</strong>
            </article>
            <article class="report-metric">
              <span class="field-label">Media</span>
              <strong id="report-average" class="report-value">0.0h</strong>
            </article>
          </div>

          <div class="report-highlight">
            <span class="field-label">Proyecto principal</span>
            <strong id="report-top-project">Sin datos todavia</strong>
          </div>

          <div class="button-grid compact-grid">
            <button id="preview-btn" class="ghost-btn" type="button">Vista previa</button>
            <button id="copy-report-btn" class="ghost-btn" type="button">Copiar resumen</button>
            <button id="export-btn" class="primary-btn" type="button">Exportar CSV</button>
            <label class="ghost-btn file-btn" title="Importar CSV exportado anteriormente">
              Importar CSV
              <input id="import-input" type="file" accept=".csv" class="hidden" />
            </label>
          </div>
        </section>
      </section>

      <section class="panel stack-lg">
        <div class="section-head">
          <div>
            <p class="eyebrow">Busqueda</p>
            <h2 class="section-title">Filtros de trabajo</h2>
          </div>
          <button id="clear-filters-btn" class="ghost-btn compact-btn" type="button">Limpiar</button>
        </div>

        <div class="chip-row">
          <button class="period-btn chip-btn active" data-period="all" type="button">Todo</button>
          <button class="period-btn chip-btn" data-period="today" type="button">Hoy</button>
          <button class="period-btn chip-btn" data-period="week" type="button">Semana</button>
          <button class="period-btn chip-btn" data-period="custom" type="button">Rango</button>
        </div>

        <div class="filter-grid">
          <div class="stack-sm">
            <label class="field-label" for="search-input">Buscar texto</label>
            <input id="search-input" class="field-input" type="search" placeholder="Proyecto o nota" />
          </div>
          <div class="stack-sm">
            <label class="field-label" for="project-filter">Proyecto</label>
            <select id="project-filter" class="field-input select-input">
              <option value="">Todos</option>
            </select>
          </div>
          <div class="stack-sm">
            <label class="field-label" for="from-date">Desde</label>
            <input id="from-date" class="field-input" type="date" />
          </div>
          <div class="stack-sm">
            <label class="field-label" for="to-date">Hasta</label>
            <input id="to-date" class="field-input" type="date" />
          </div>
        </div>
      </section>

      <section class="panel stack-lg">
        <div class="section-head">
          <div>
            <p class="eyebrow">Historial</p>
            <h2 class="section-title">Sesiones registradas</h2>
          </div>
          <p class="tiny-copy">Abre una sesion para editar fecha, hora, proyecto, nota, duplicar, partir o fusionar.</p>
        </div>

        <ul id="records-list" class="records-list"></ul>
      </section>
    </main>
  </div>

  <div id="entry-modal" class="modal-shell hidden" role="dialog" aria-modal="true" aria-labelledby="entry-modal-title">
    <div class="modal-backdrop" data-close-entry></div>
    <div class="modal-card">
      <div class="section-head">
        <div>
          <p class="eyebrow">Registro</p>
          <h2 id="entry-modal-title" class="section-title">Editar sesion</h2>
        </div>
        <button id="entry-close" class="ghost-btn compact-btn" type="button">Cerrar</button>
      </div>

      <form id="entry-form" class="stack-lg">
        <input id="entry-id" type="hidden" />
        <div class="modal-grid">
          <div class="stack-sm">
            <label class="field-label" for="entry-date-input">Fecha</label>
            <input id="entry-date-input" class="field-input" type="date" required />
          </div>
          <div class="stack-sm">
            <label class="field-label" for="entry-start-input">Inicio</label>
            <input id="entry-start-input" class="field-input" type="time" required />
          </div>
          <div class="stack-sm">
            <label class="field-label" for="entry-end-input">Fin</label>
            <input id="entry-end-input" class="field-input" type="time" required />
          </div>
        </div>

        <div class="stack-sm">
          <label class="field-label" for="entry-project-input">Proyecto</label>
          <input id="entry-project-input" class="field-input" type="text" maxlength="50" />
        </div>

        <div class="stack-sm">
          <label class="field-label" for="entry-note-input">Nota</label>
          <textarea id="entry-note-input" class="field-input textarea-input" rows="3" maxlength="200"></textarea>
        </div>

        <div class="split-row">
          <div class="stack-sm">
            <label class="field-label" for="entry-split-input">Partir en</label>
            <input id="entry-split-input" class="field-input" type="time" />
          </div>
          <button id="entry-split-btn" class="ghost-btn" type="button">Partir sesion</button>
        </div>

        <div class="stack-sm">
          <span class="field-label">Fusionar con sesion cercana</span>
          <div id="merge-actions" class="chip-row"></div>
        </div>

        <div class="button-grid compact-grid">
          <button id="entry-save-btn" class="primary-btn" type="submit">Guardar cambios</button>
          <button id="entry-duplicate-btn" class="ghost-btn" type="button">Duplicar</button>
          <button id="entry-delete-btn" class="ghost-btn danger-btn" type="button">Eliminar</button>
        </div>
      </form>
    </div>
  </div>

  <div id="csv-modal" class="modal-shell hidden" role="dialog" aria-modal="true" aria-labelledby="csv-title">
    <div class="modal-backdrop" data-close-preview></div>
    <div class="modal-card wide-card">
      <div class="section-head">
        <div>
          <p class="eyebrow">Exportacion</p>
          <h2 id="csv-title" class="section-title">Vista previa CSV</h2>
        </div>
        <button id="csv-close" class="ghost-btn compact-btn" type="button">Cerrar</button>
      </div>

      <div class="stack-md">
        <p id="csv-summary" class="tiny-copy"></p>
        <span id="csv-count" class="status-badge">0 registros</span>
      </div>

      <div class="table-shell">
        <table id="csv-table" class="preview-table"></table>
      </div>

      <div class="button-grid compact-grid">
        <button id="csv-download-modal" class="primary-btn" type="button">Descargar CSV</button>
      </div>
    </div>
  </div>

  <div id="toast" class="toast hidden" role="status" aria-live="polite">
    <span id="toast-msg"></span>
    <button id="toast-action" class="hidden toast-action" type="button"></button>
  </div>
</Layout>

<script>
  import "../scripts/timelog.ts";
</script>
